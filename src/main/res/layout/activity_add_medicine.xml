<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img">

    <!-- HEADER -->
    <TextView
        android:id="@+id/textView3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/header_background_color"
        android:elevation="4dp"
        android:fontFamily="sans-serif-medium"
        android:paddingTop="40dp"
        android:paddingBottom="40dp"
        android:text="Set Dose Schedule"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MAIN FORM -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textView3"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- MEDICINE NAME -->
        <EditText
            android:id="@+id/editTextText3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_edittext_bg"
            android:drawableStart="@drawable/c"
            android:drawablePadding="12dp"
            android:hint="Medicine Name"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="#373534"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp" />

        <!-- DOSE -->
        <EditText
            android:id="@+id/editTextText4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/rounded_edittext_bg"
            android:drawableStart="@drawable/d"
            android:drawablePadding="12dp"
            android:hint="Dose (e.g., 1 tablet, 5ml)"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="#373534"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp" />

        <!-- TIME -->
        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/rounded_edittext_bg"
            android:clickable="true"
            android:focusable="true"
            android:drawableStart="@drawable/e"
            android:drawablePadding="12dp"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:text="Select Time"
            android:textColor="#9E9E9E"
            android:textSize="16sp" />

        <!-- REPEAT DROPDOWN (Old feature maintained) -->
        <Spinner
            android:id="@+id/spinnerRepeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#9E9E9E"
            android:background="@drawable/rounded_edittext_bg"/>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/button2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="#00BCD4"
            android:padding="12dp"
            android:text="Save Reminder"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:elevation="6dp"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>